{
  "buildCommand": "cd ui && npm install --include=dev && npm run build",
  "outputDirectory": "ui/dist",
  "installCommand": "npm install --include=dev",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/.well-known/:path*", "destination": "/api" },
    { "source": "/actor", "destination": "/api" },
    { "source": "/inbox", "destination": "/api" },
    { "source": "/outbox", "destination": "/api" },
    { "source": "/nodeinfo/:path*", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/internal/digest/run",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/api/internal/meeting-summary/run",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/internal/floyd-news-sync/run",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/internal/admin-digest/run",
      "schedule": "30 13 * * *"
    }
  ]
}

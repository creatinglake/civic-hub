{
  "name": "civic-hub",
  "version": "0.1.0",
  "description": "Reference implementation of a Civic Hub backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --env-file=.env --import tsx --watch src/index.ts",
    "test:flow": "tsx scripts/testFlow.ts",
    "seed": "curl -s http://localhost:3000/debug/seed | node -e \"process.stdin.on('data',d=>{const j=JSON.parse(d);console.log(j.message);j.processes.forEach(p=>console.log('  '+p.status.padEnd(6)+' '+p.title));console.log(j.event_count+' events emitted')})\""
  },
  "keywords": [
    "civic",
    "hub",
    "governance",
    "civic-social"
  ],
  "engines": {
    "node": "20.x"
  },
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.103.3",
    "@types/nodemailer": "^8.0.0",
    "cheerio": "^1.2.0",
    "express": "^4.21.0",
    "nodemailer": "^8.0.5",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

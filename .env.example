# Copy this file to .env (which is gitignored) and fill in real values.
# Vercel: set the same vars under Project Settings → Environment Variables,
# one value per environment (Production / Preview / Development).

# --- Supabase ---
# Project URL, e.g. https://nfhyy…supabase.co
SUPABASE_URL=

# Service role SECRET key (starts with sb_secret_…). NEVER commit or expose
# to a browser. Find it in Supabase → Settings → API Keys → Secret keys.
SUPABASE_SERVICE_ROLE_KEY=

# --- Hub config ---
# Public URL the hub advertises as its API origin in events (source.hub_url)
# and the discovery manifest.
# Local dev: http://localhost:3000
# Production: https://floyd.civic.social  (or whatever your domain is)
BASE_URL=http://localhost:3000

# Public URL the hub uses when constructing user-facing action_url values
# on emitted events (per Civic Event Spec §3 — "link to take action").
# Falls back to BASE_URL if unset, which is correct for single-origin
# deployments where the UI and API share a hostname (e.g. Vercel). In
# split-origin local dev (API on :3000, UI on :5173) set this to the UI
# origin so feed posts navigate to the UI, not the JSON API.
# Local split-origin dev: http://localhost:5173
CIVIC_UI_BASE_URL=

# Port for the local dev server (defaults to 3000 if unset).
PORT=3000

# --- Security ---
# Comma-separated list of allowed Origins for CORS.
# Example (production): https://floyd.civic.social,https://civic.social
# If unset AND NODE_ENV !== "production", all origins are allowed (dev convenience).
# If unset in production, the server refuses to start.
CIVIC_ALLOWED_ORIGINS=

# Comma-separated list of admin emails. Admin routes (/admin/*) require the
# authenticated user's email to appear in this list (case-insensitive).
# If unset, all admin routes return 503 (safe-by-default — no silent admins).
# Admins can do everything Board members can (see CIVIC_BOARD_EMAILS) plus
# proposal review, brief review/approval, and delivery settings.
CIVIC_ADMIN_EMAILS=

# Comma-separated list of Board member emails. Narrow role: users in this
# list can post and edit /announcement/* entries but cannot access any
# /admin/* route. If a user's email is in both CIVIC_ADMIN_EMAILS and
# CIVIC_BOARD_EMAILS, admin wins (full privileges). Case-insensitive.
# If unset, nobody has the board role — only admins can post announcements.
CIVIC_BOARD_EMAILS=

# Node environment. Set to "production" on Vercel Production.
NODE_ENV=development

# --- Email (Resend) ---
# Resend API key (starts with re_…). Get it from resend.com → API Keys.
# If unset, the OTP is logged to console as a dev fallback (no email sent).
RESEND_API_KEY=

# The "From" header for outbound email. Must be on a domain you've
# verified in Resend (DNS records configured). Example:
#   Floyd Civic Hub <noreply@floyd.civic.social>
# If unset, defaults to the Resend sandbox sender (onboarding@resend.dev).
RESEND_FROM=

# --- Dev-only toggles ---
# When "true", /debug/seed is allowed to wipe and reseed data, and the
# ensureSeeded middleware will auto-seed an empty database on first request.
# MUST be unset (or "false") in Production.
CIVIC_ALLOW_SEED=true

# If set, accepts this value as a bypass OTP code in /auth/verify. Useful
# for local dev and preview to skip real email delivery. MUST be unset
# in Production so real verification is enforced.
CIVIC_DEMO_BYPASS_CODE=000000

# --- SMTP (Civic Brief delivery) ---
# When all five SMTP_* vars below are set, admin approval of a Civic Brief
# delivers the formatted brief to BOARD_RECIPIENT_EMAIL via nodemailer.
# When any of them are unset, email delivery falls back to console logging
# (visible in the server logs) and the approval flow treats delivery as
# successful. This keeps local dev runnable without SMTP credentials.
# SMTP_PORT 465 uses TLS; 587 uses STARTTLS.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Fallback recipient list for Civic Brief delivery. Comma-separated
# multi-recipient supported. As of Slice 3 addendum, the admin UI has a
# "Delivery settings" panel under /admin/briefs that writes to the
# hub_settings table. The backend reads the DB setting first and falls
# back to this env var only if no DB row exists, so once an admin saves
# recipients in the UI this env var is effectively ignored.
BOARD_RECIPIENT_EMAIL=

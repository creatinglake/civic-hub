# Copy this file to .env (which is gitignored) and fill in real values.
# Vercel: set the same vars under Project Settings → Environment Variables,
# one value per environment (Production / Preview / Development).

# --- Supabase ---
# Project URL, e.g. https://nfhyy…supabase.co
SUPABASE_URL=

# Service role SECRET key (starts with sb_secret_…). NEVER commit or expose
# to a browser. Find it in Supabase → Settings → API Keys → Secret keys.
SUPABASE_SERVICE_ROLE_KEY=

# --- Hub config ---
# Public URL the hub advertises in events and the discovery manifest.
# Local dev: http://localhost:3000
# Production: https://floyd.civic.social  (or whatever your domain is)
BASE_URL=http://localhost:3000

# Port for the local dev server (defaults to 3000 if unset).
PORT=3000

# --- Security ---
# Comma-separated list of allowed Origins for CORS.
# Example (production): https://floyd.civic.social,https://civic.social
# If unset AND NODE_ENV !== "production", all origins are allowed (dev convenience).
# If unset in production, the server refuses to start.
CIVIC_ALLOWED_ORIGINS=

# Comma-separated list of admin emails. Admin routes (/admin/*) require the
# authenticated user's email to appear in this list (case-insensitive).
# If unset, all admin routes return 503 (safe-by-default — no silent admins).
CIVIC_ADMIN_EMAILS=

# Node environment. Set to "production" on Vercel Production.
NODE_ENV=development

# --- Email (Resend) ---
# Resend API key (starts with re_…). Get it from resend.com → API Keys.
# If unset, the OTP is logged to console as a dev fallback (no email sent).
RESEND_API_KEY=

# The "From" header for outbound email. Must be on a domain you've
# verified in Resend (DNS records configured). Example:
#   Floyd Civic Hub <noreply@floyd.civic.social>
# If unset, defaults to the Resend sandbox sender (onboarding@resend.dev).
RESEND_FROM=

# --- Dev-only toggles ---
# When "true", /debug/seed is allowed to wipe and reseed data, and the
# ensureSeeded middleware will auto-seed an empty database on first request.
# MUST be unset (or "false") in Production.
CIVIC_ALLOW_SEED=true

# If set, accepts this value as a bypass OTP code in /auth/verify. Useful
# for local dev and preview to skip real email delivery. MUST be unset
# in Production so real verification is enforced.
CIVIC_DEMO_BYPASS_CODE=000000
